# Copy to `.env` and fill in real values (DO NOT commit `.env`)

# App / Supabase Postgres
FLASK_ENV=production
SECRET_KEY=replace-with-a-secure-secret

# Database (Supabase Postgres URL)
# Example: postgresql+psycopg2://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# When deploying to platforms that may prefer IPv4 egress (e.g. some Vercel regions),
# set this to 'true' to force the app to resolve the database hostname to an IPv4 address.
# Example: FORCE_IPV4=true
FORCE_IPV4=

# Admin user
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=

# Default employee user
EMPLOYEE_EMAIL=sakshi@example.com
EMPLOYEE_PASSWORD=
EMPLOYEE_FULL_NAME=Sakshi

# Data import source
# Keep Excel files in the local Data/ folder.
